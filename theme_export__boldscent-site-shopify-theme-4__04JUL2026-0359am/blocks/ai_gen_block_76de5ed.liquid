{% doc %}

  @prompt

    A quote section

{% enddoc %}

{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}



{% style %}

  .ai-quote-section-{{ ai_gen_id }} {

    display: block;

    width: {{ block.settings.desktop_width_percent }}%;

    max-width: 100%;

    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;

    background-color: {{ block.settings.background_color }};

    margin: 0 auto;

  }



  .ai-quote-section__container-{{ ai_gen_id }} {

    max-width: {{ block.settings.max_width }}px;

    margin: 0 auto;

    text-align: {{ block.settings.text_alignment }};

  }



  .ai-quote-section__icon-{{ ai_gen_id }} {

    color: {{ block.settings.icon_color }};

    margin-bottom: {{ block.settings.icon_spacing }}px;

    opacity: {{ block.settings.icon_opacity }};

  }



  .ai-quote-section__icon-{{ ai_gen_id }} svg {

    width: {{ block.settings.icon_size }}px;

    height: {{ block.settings.icon_size }}px;

    display: inline-block;

  }



  .ai-quote-section__quote-{{ ai_gen_id }} {

    font-family: {{ block.settings.quote_font.family }}, {{ block.settings.quote_font.fallback_families }};

    font-weight: {{ block.settings.quote_font.weight }};

    font-style: {{ block.settings.quote_font.style }};

    font-size: {{ block.settings.quote_size }}px;

    line-height: {{ block.settings.quote_line_height }};

    color: {{ block.settings.quote_color }};

    margin: 0 0 {{ block.settings.quote_spacing }}px;

  }



  .ai-quote-section__author-{{ ai_gen_id }} {

    font-family: {{ block.settings.author_font.family }}, {{ block.settings.author_font.fallback_families }};

    font-weight: {{ block.settings.author_font.weight }};

    font-style: {{ block.settings.author_font.style }};

    font-size: {{ block.settings.author_size }}px;

    color: {{ block.settings.author_color }};

    margin: 0;

  }



  .ai-quote-section__divider-{{ ai_gen_id }} {

    width: {{ block.settings.divider_width }}px;

    height: {{ block.settings.divider_height }}px;

    background-color: {{ block.settings.divider_color }};

    margin: {{ block.settings.divider_spacing }}px auto;

    {% if block.settings.text_alignment == 'left' %}

      margin-left: 0;

    {% elsif block.settings.text_alignment == 'right' %}

      margin-right: 0;

    {% endif %}

  }



  @media screen and (max-width: 749px) {

    .ai-quote-section-{{ ai_gen_id }} {

      padding: {{ block.settings.padding_top | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px {{ block.settings.padding_bottom | times: 0.7 }}px;

    }



    .ai-quote-section__icon-{{ ai_gen_id }} svg {

      width: {{ block.settings.icon_size | times: 0.8 }}px;

      height: {{ block.settings.icon_size | times: 0.8 }}px;

    }



    .ai-quote-section__quote-{{ ai_gen_id }} {

      font-size: {{ block.settings.quote_size | times: 0.8 }}px;

    }



    .ai-quote-section__author-{{ ai_gen_id }} {

      font-size: {{ block.settings.author_size | times: 0.9 }}px;

    }

  }

{% endstyle %}



<div class="ai-quote-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>

  <div class="ai-quote-section__container-{{ ai_gen_id }}">

    {% if block.settings.show_icon %}

      <div class="ai-quote-section__icon-{{ ai_gen_id }}">

        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">

          <path d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z"/>

        </svg>

      </div>

    {% endif %}



    {% if block.settings.quote != blank %}

      <blockquote class="ai-quote-section__quote-{{ ai_gen_id }}">

        {{ block.settings.quote }}

      </blockquote>

    {% endif %}



    {% if block.settings.show_divider %}

      <div class="ai-quote-section__divider-{{ ai_gen_id }}"></div>

    {% endif %}



    {% if block.settings.author != blank %}

      <p class="ai-quote-section__author-{{ ai_gen_id }}">

        {{ block.settings.author }}

      </p>

    {% endif %}

  </div>

</div>



{% schema %}

{

  "name": "Quote section",

  "settings": [

    {

      "type": "header",

      "content": "Content"

    },

    {

      "type": "richtext",

      "id": "quote",

      "label": "Quote",

      "default": "<p>Fragrance is the invisible accessory that completes every outfit.</p>"

    },

    {

      "type": "text",

      "id": "author",

      "label": "Author"

    },

    {

      "type": "header",

      "content": "Layout"

    },

    {

      "type": "range",

      "id": "desktop_width_percent",

      "label": "Desktop width",

      "min": 50,

      "max": 100,

      "step": 5,

      "unit": "%",

      "default": 100

    },

    {

      "type": "range",

      "id": "max_width",

      "label": "Content max width",

      "min": 400,

      "max": 1200,

      "step": 50,

      "unit": "px",

      "default": 800

    },

    {

      "type": "select",

      "id": "text_alignment",

      "label": "Text alignment",

      "options": [

        {

          "value": "left",

          "label": "Left"

        },

        {

          "value": "center",

          "label": "Center"

        },

        {

          "value": "right",

          "label": "Right"

        }

      ],

      "default": "center"

    },

    {

      "type": "range",

      "id": "padding_top",

      "label": "Padding top",

      "min": 0,

      "max": 100,

      "step": 5,

      "unit": "px",

      "default": 60

    },

    {

      "type": "range",

      "id": "padding_bottom",

      "label": "Padding bottom",

      "min": 0,

      "max": 100,

      "step": 5,

      "unit": "px",

      "default": 60

    },

    {

      "type": "range",

      "id": "padding_horizontal",

      "label": "Padding horizontal",

      "min": 0,

      "max": 100,

      "step": 5,

      "unit": "px",

      "default": 20

    },

    {

      "type": "header",

      "content": "Quote icon"

    },

    {

      "type": "checkbox",

      "id": "show_icon",

      "label": "Show quote icon",

      "default": true

    },

    {

      "type": "range",

      "id": "icon_size",

      "label": "Icon size",

      "min": 20,

      "max": 80,

      "step": 5,

      "unit": "px",

      "default": 40

    },

    {

      "type": "range",

      "id": "icon_spacing",

      "label": "Icon spacing",

      "min": 0,

      "max": 40,

      "step": 5,

      "unit": "px",

      "default": 20

    },

    {

      "type": "range",

      "id": "icon_opacity",

      "label": "Icon opacity",

      "min": 0,

      "max": 1,

      "step": 0.1,

      "default": 0.3

    },

    {

      "type": "color",

      "id": "icon_color",

      "label": "Icon color",

      "default": "#C8A060"

    },

    {

      "type": "header",

      "content": "Quote text"

    },

    {

      "type": "font_picker",

      "id": "quote_font",

      "label": "Font",

      "default": "playfair_display_n4"

    },

    {

      "type": "range",

      "id": "quote_size",

      "label": "Font size",

      "min": 16,

      "max": 48,

      "step": 2,

      "unit": "px",

      "default": 28

    },

    {

      "type": "range",

      "id": "quote_line_height",

      "label": "Line height",

      "min": 1,

      "max": 2,

      "step": 0.1,

      "default": 1.5

    },

    {

      "type": "range",

      "id": "quote_spacing",

      "label": "Bottom spacing",

      "min": 0,

      "max": 50,

      "step": 5,

      "unit": "px",

      "default": 25

    },

    {

      "type": "color",

      "id": "quote_color",

      "label": "Text color",

      "default": "#F7F4EE"

    },

    {

      "type": "header",

      "content": "Divider"

    },

    {

      "type": "checkbox",

      "id": "show_divider",

      "label": "Show divider",

      "default": true

    },

    {

      "type": "range",

      "id": "divider_width",

      "label": "Width",

      "min": 20,

      "max": 200,

      "step": 10,

      "unit": "px",

      "default": 60

    },

    {

      "type": "range",

      "id": "divider_height",

      "label": "Height",

      "min": 1,

      "max": 5,

      "step": 1,

      "unit": "px",

      "default": 2

    },

    {

      "type": "range",

      "id": "divider_spacing",

      "label": "Spacing",

      "min": 10,

      "max": 40,

      "step": 5,

      "unit": "px",

      "default": 20

    },

    {

      "type": "color",

      "id": "divider_color",

      "label": "Color",

      "default": "#C8A060"

    },

    {

      "type": "header",

      "content": "Author"

    },

    {

      "type": "font_picker",

      "id": "author_font",

      "label": "Font",

      "default": "montserrat_n4"

    },

    {

      "type": "range",

      "id": "author_size",

      "label": "Font size",

      "min": 12,

      "max": 24,

      "step": 1,

      "unit": "px",

      "default": 16

    },

    {

      "type": "color",

      "id": "author_color",

      "label": "Text color",

      "default": "#C8A060"

    },

    {

      "type": "header",

      "content": "Colors"

    },

    {

      "type": "color",

      "id": "background_color",

      "label": "Background",

      "default": "#0B0B0B"

    }

  ],

  "presets": [

    {

      "name": "Quote section"

    }

  ]

}

{% endschema %} 

