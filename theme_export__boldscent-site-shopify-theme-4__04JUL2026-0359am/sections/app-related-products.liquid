{% comment %}
  Luxury Related Products Carousel - 100% Signature Collection Match (Fixed Proportions)
{% endcomment %}

<div class="luxury-app-recommendations" 
     data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ section.settings.products_to_show }}">
  
  {% comment %} 
    العنوان والـ Divider ثابتين هنا برة عشان نضمن إن الجافا سكريبت متلمسهمش ولا تخفيهم أبداً
  {% endcomment %}
  {% if section.settings.title != blank %}
    <div class="page-width luxury-carousel-container section-header-fixed">
      <div class="text-center">
        <h2 class="luxury-title">{{ section.settings.title }}</h2>
        <div class="luxury-divider"></div>
      </div>
    </div>
  {% endif %}

  {% if recommendations.performed and recommendations.products_count > 0 %}
    <div class="page-width luxury-carousel-container" id="LuxuryRecommendationsContent">
      
      <div class="luxury-carousel-wrapper">
        
        <div class="luxury-top-scrollbar-line">
          <div class="luxury-scrollbar-progress" id="ScrollProgress"></div>
        </div>
        
        <div class="luxury-carousel-slider" id="LuxurySlider">
          {% for prod in recommendations.products %}
            <div class="luxury-carousel__item">
              <div class="perfume-card-luxury">
                <a href="{{ prod.url }}" class="perfume-card__link">
                  <div class="perfume-card__image-wrapper">
                    <img class="perfume-card__image" src="{{ prod.featured_media | image_url: width: 600 }}" alt="{{ prod.title | escape }}" loading="lazy">
                  </div>
                  <div class="perfume-card__info">
                    <h3 class="perfume-card__title">{{ prod.title }}</h3>
                    
                    <p class="perfume-card__subtitle">
                      {% if prod.metafields.custom.fragrance_notes != blank %}
                        {{ prod.metafields.custom.fragrance_notes }}
                      {% else %}
                        {{ prod.type | default: "Luxury Fragrance" }}
                      {% endif %}
                    </p>

                    <div class="perfume-card__price">
                      {{ prod.price | money }}
                    </div>
                  </div>
                </a>
              </div>
            </div>
          {% endfor %}
        </div>
        
      </div>

    </div>
  {% endif %}
</div>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    const handleIntersection = (entries, observer) => {
      if (!entries[0].isIntersecting) return;
      observer.unobserve(productRecommendationsSection);

      fetch(productRecommendationsSection.dataset.url)
        .then(response => response.text())
        .then(text => {
          const html = new DOMParser().parseFromString(text, 'text/html');
          // هنا بنسحب فقط محتوى الكاروسيل الداخلي عشان نحدثه بدون ما نلمس العنوان الثابت فوق
          const recommendationsContent = html.querySelector('#LuxuryRecommendationsContent');

          if (recommendationsContent && recommendationsContent.innerHTML.trim().length > 0) {
            // نتحقق إذا كان فيه حاوية قديمة نحدثها، أو ننشئها لو مش موجودة
            let currentContent = productRecommendationsSection.querySelector('#LuxuryRecommendationsContent');
            if (currentContent) {
              currentContent.innerHTML = recommendationsContent.innerHTML;
            } else {
              productRecommendationsSection.insertAdjacentHTML('beforeend', recommendationsContent.outerHTML);
            }
            initializeScrollIndicator();
          }
        })
        .catch(e => console.error(e));
    };

    const productRecommendationsSection = document.querySelector('.luxury-app-recommendations');
    if (!productRecommendationsSection) return;

    const observer = new IntersectionObserver(handleIntersection, {rootMargin: '0px 0px 400px 0px'});
    observer.observe(productRecommendationsSection);

    function initializeScrollIndicator() {
      const slider = document.getElementById('LuxurySlider');
      const progress = document.getElementById('ScrollProgress');
      if (!slider || !progress) return;

      slider.addEventListener('scroll', () => {
        const maxScroll = slider.scrollWidth - slider.clientWidth;
        if (maxScroll <= 0) return;
        const percentage = (slider.scrollLeft / maxScroll) * 100;
        progress.style.width = `${percentage}%`;
      });
    }
  });
</script>

<style>
.luxury-app-recommendations {
  background-color: #000000;
  color: #F7F4EE;
  padding: 60px 0;
  border-top: 1px solid #111111;
  overflow: hidden;
}
.luxury-carousel-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px;
}
.section-header-fixed {
  margin-bottom: 10px;
}
.luxury-title {
  font-family: "Playfair Display", serif;
  color: #C8A060;
  font-size: 28px;
  letter-spacing: 1px;
  margin-bottom: 12px;
  text-align: center;
}
.luxury-divider {
  width: 50px;
  height: 1px;
  background-color: #C8A060;
  margin: 0 auto 25px;
}

.luxury-carousel-wrapper {
  display: flex;
  flex-direction: column;
  position: relative;
}

.luxury-top-scrollbar-line {
  width: 100%;
  max-width: 200px;
  height: 1px;
  background: #242424;
  margin: 0 auto 35px auto;
  position: relative;
  overflow: hidden;
}
.luxury-scrollbar-progress {
  position: absolute;
  top: 0;
  left: 0;
  height: 100%;
  width: 0%;
  background: #C8A060;
  transition: width 0.1s ease-out;
}

.luxury-carousel-slider {
  display: flex;
  flex-wrap: nowrap;
  gap: 25px;
  overflow-x: auto;
  overflow-y: hidden;
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;
  -webkit-overflow-scrolling: touch;
  padding-bottom: 15px;
}

.luxury-carousel-slider::-webkit-scrollbar {
  display: none;
}
.luxury-carousel-slider {
  -ms-overflow-style: none;
  scrollbar-width: none;
}

.luxury-carousel__item {
  flex: 0 0 calc(25% - 19px);
  min-width: 240px;
  scroll-snap-align: start;
}

.perfume-card-luxury {
  background: #111111;
  border: 1px solid #242424;
  border-radius: 0px; 
  overflow: hidden;
  display: flex;
  flex-direction: column;
  height: 100%;
}

.perfume-card__link {
  text-decoration: none;
  color: inherit;
  display: flex;
  flex-direction: column;
  height: 100%;
}

.perfume-card__image-wrapper {
  position: relative;
  width: 100%;
  padding-bottom: 135%; 
  background-color: #050505;
  overflow: hidden;
}
.perfume-card__image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover; 
  transition: transform 0.5s cubic-bezier(0.25, 1, 0.5, 1);
}
.perfume-card-luxury:hover .perfume-card__image {
  transform: scale(1.02);
}

.perfume-card__info {
  padding: 20px 12px;
  text-align: center;
}
.perfume-card__title {
  font-family: "Playfair Display", serif;
  font-size: 18px;
  font-weight: 400;
  color: #F7F4EE;
  margin: 0 0 6px 0;
}
.perfume-card__subtitle {
  font-family: "Montserrat", sans-serif;
  font-size: 12px;
  color: #A3ADB5;
  margin: 0 0 10px 0;
  line-height: 1.3;
}
.perfume-card__price {
  font-family: "Montserrat", sans-serif;
  color: #C8A060;
  font-size: 15px;
  font-weight: 500;
}

@media (max-width: 992px) {
  .luxury-carousel__item {
    flex: 0 0 calc(40% - 12px);
    min-width: 200px;
  }
}

@media (max-width: 768px) {
  .luxury-app-recommendations {
    padding: 40px 0;
  }
  .luxury-carousel-container {
    padding: 0 16px;
  }
  .luxury-title {
    font-size: 24px;
    margin-bottom: 8px;
  }
  .luxury-divider {
    margin-bottom: 25px;
  }
  .luxury-top-scrollbar-line {
    max-width: 140px;
    margin-bottom: 25px;
  }
  .luxury-carousel-slider {
    gap: 16px;
  }
  
  .luxury-carousel__item {
    flex: 0 0 calc(50% - 8px); 
    min-width: 150px;
  }
  
  .perfume-card__image-wrapper {
    padding-bottom: 130%; 
  }
  
  .perfume-card__info {
    padding: 12px 8px;
  }
  .perfume-card__title {
    font-size: 15px;
  }
  .perfume-card__subtitle {
    font-size: 11px;
  }
  .perfume-card__price {
    font-size: 13px;
  }
}
</style>