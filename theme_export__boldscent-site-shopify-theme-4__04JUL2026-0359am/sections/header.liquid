<header class="site-header" id="siteHeader">
  <div class="container header-inner">

    <div class="mobile-left-nav">
      <button class="mobile-menu-btn" id="mobileMenuBtn" type="button" aria-label="Open menu">
        {% render 'icon', name: 'menu' %}
      </button>
      <button class="icon-btn" id="searchBtnMobile" type="button" aria-label="Search">
        {% render 'icon', name: 'search' %}
      </button>
    </div>

    <div class="logo">
      <a href="{{ routes.root_url }}">
        <span class="logo-text">{{ shop.name }}</span>
      </a>
    </div>

    <nav class="desktop-nav">
      <a href="{{ routes.all_products_collection_url }}">Shop</a>
      <a href="{{ routes.collections_url }}">Collection</a>
      <a href="/products/discovery-set">Discovery Set</a> {% comment %} تم إضافة الرابط هنا بالتناسق مع المنيو {% endcomment %}
      <a href="/pages/wishlist">Wishlist</a>
      <a href="/pages/about">About</a>
      <a href="/pages/contact">Contact</a>
    </nav>

    <div class="header-actions">
      <div class="utility-nav">
        <button class="icon-btn desktop-search-btn" id="searchBtn" type="button" aria-label="Search">
          {% render 'icon', name: 'search' %}
        </button>
        
        <a href="{{ routes.account_url }}" class="icon-btn" aria-label="Account">
          {% render 'icon', name: 'account' %}
        </a>
        
        <button class="icon-btn cart-trigger" id="cartBtn" type="button" aria-label="Cart">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="9" cy="21" r="1"></circle>
            <circle cx="20" cy="21" r="1"></circle>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
          </svg>
          <span class="cart-count">{{ cart.item_count }}</span>
        </button>
      </div>
    </div>

  </div>
</header>

<style>
/* ---------------------------------------------------------
   ✨ التنسيقات الأساسية والديسكتوب (Luxury Minimal)
   --------------------------------------------------------- */
.site-header {
  position: sticky;
  top: 0;
  z-index: 1000;
  background: #0B0B0B;
  border-bottom: 1px solid #242424;
}

a {
  text-decoration: none;
}

.header-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px 0;
}

.logo-text {
  font-family: "Playfair Display";
  font-size: 28px;
  color: #C8A060;
  letter-spacing: 4px;
  text-decoration: none;
  line-height: 1;
}

.desktop-nav a {
  margin: 0 15px;
  font-family: Montserrat;
  color: #F7F4EE;
  text-decoration: none;
  font-size: 14px;
}

.header-actions {
  display: flex;
  align-items: center;
}

.utility-nav {
  display: flex;
  align-items: center;
  gap: 18px; /* مسافة فخمة ومريحة تناسب الحجم الجديد */
}

.mobile-left-nav {
  display: none;
}

/* ---------------------------------------------------------
   🚀 توحيد الأزرار والأيقونات هندسياً بالملي (الحجم الجديد الكبير)
   --------------------------------------------------------- */
.icon-btn, .mobile-menu-btn {
  background: none !important;
  border: none !important;
  padding: 0 !important;
  margin: 0 !important;
  color: #F7F4EE !important;
  cursor: pointer;
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  width: 28px !important;  /* كادر الزرار يستوعب الأيقونات براحتها */
  height: 28px !important; 
  box-sizing: border-box !important;
}

/* حجم الـ SVG الداخلي لكل الأيقونات بالتساوي لتتطابق مع الـ Menu والـ Search */
.icon-btn svg, .mobile-menu-btn svg {
  width: 25px !important;  /* الحجم الفخم للأيقونات بالتساوي في اليمين والشمال */
  height: 25px !important; 
  display: block !important;
}

/* ---------------------------------------------------------
   🎯 العداد الطائر (معدل بدقة بالبكسل ليناسب الحجم الكبير الجديد)
   --------------------------------------------------------- */
.cart-trigger {
  position: relative !important;
  overflow: visible !important; 
}

.cart-count {
  position: absolute !important;
  top: -3px !important;   /* ترحيل ميكروسكوبي ليظل طافياً بشكل مثالي فوق الـ 25px */
  right: -4px !important; 
  background: #C8A060 !important;
  color: #0B0B0B !important;
  font-family: Montserrat, sans-serif !important;
  font-size: 9px !important;
  font-weight: 700 !important;
  min-width: 14px !important;
  height: 14px !important;
  border-radius: 50% !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  padding: 0 3px !important;
  box-sizing: border-box !important;
  z-index: 10 !important;
  line-height: 1 !important;
}

/* ---------------------------------------------------------
    📱 تنسيق الموبايل
   --------------------------------------------------------- */
@media(max-width:768px){
  .desktop-nav, .desktop-search-btn {
    display: none !important;
  }

  .header-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr; 
    align-items: center;
    padding: 15px 0;
  }

  .mobile-left-nav {
    display: flex;
    align-items: center;
    gap: 15px; 
    justify-content: flex-start;
  }

  .logo {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .logo-text {
    font-size: 24px; 
    letter-spacing: 3px;
  }

  .header-actions {
    display: flex;
    justify-content: flex-end;
    align-items: center;
  }

  .utility-nav {
    gap: 15px; 
  }
}
</style>