<div class="auth container">

  <h2>Login</h2>

  {% form 'customer_login' %}
    {{ form.errors | default_errors }}

    <input type="email" name="customer[email]" placeholder="Email" required autocomplete="email">
    <input type="password" name="customer[password]" placeholder="Password" required autocomplete="current-password">

    <button type="submit" class="btn-primary">Login</button>
  {% endform %}

  <p class="auth-link">
    <a href="{{ routes.account_recover_url | default: routes.account_login_url }}" class="forgot-password">Forgot password?</a>
  </p>

  <p class="auth-link">
    <a href="{{ routes.account_register_url }}">Create an account</a>
  </p>

  <div class="social-login" aria-label="Social login">
    <button type="button" class="btn-secondary social-btn" disabled aria-disabled="true">Continue with Google</button>
    <button type="button" class="btn-secondary social-btn" disabled aria-disabled="true">Continue with Facebook</button>
  </div>


</div>

<style>
.auth{
  max-width:400px;
  margin:100px auto;
  padding:0 20px;
}

.auth h2{
  font-family:"Playfair Display";
  color:#C8A060;
  margin-bottom:30px;
  text-align:center;
}

.auth input{
  width:100%;
  margin:10px 0;
  padding:15px;
  background:#111;
  border:1px solid #242424;
  color:#fff;
  border-radius:8px;
}

.auth button{
  width:100%;
  margin-top:10px;
}

.auth-link{
  text-align:center;
  margin-top:20px;
}

.auth-link a{
  color:#C8A060;
  font-family:Montserrat;
  font-size:14px;
  text-decoration:none;
}

.forgot-password{
  color:#C8A060;
}

.social-login{
  margin-top:22px;
  display:flex;
  gap:12px;
  flex-direction:column;
}

.social-btn{
  width:100%;
}
</style>


{% schema %}
{
  "name": "Login Form",
  "settings": []
}
{% endschema %}
