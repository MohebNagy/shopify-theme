{% assign ai_gen_id = section.id | replace: '_', '' | downcase %}

<section class="signature container" id="sig-section-{{ section.id }}">

  <h2>{{ section.settings.title }}</h2>

  <div class="grid">

    {% for block in section.blocks %}
      {%- assign featured_product = block.settings.product -%}
      {%- assign product_link = block.settings.link | default: featured_product.url | default: '#' -%}
      {%- assign perfume_name = block.settings.name | default: featured_product.title | default: 'Premium Fragrance' -%}
      
      {%- assign metafield_value = featured_product.metafields.custom.signature_statement.value | default: featured_product.metafields.custom.signature_statement -%}
      
      {%- assign display_note = metafield_value | default: block.settings.note -%}

      <a class="card scale-hover sig-anim-card" href="{{ product_link }}" {{ block.shopify_attributes }} style="--card-index: {{ forloop.index0 }};">

        {%- assign card_image = block.settings.image | default: featured_product.featured_image -%}
        {% if card_image %}
          <img
            src="{{ card_image | image_url: width: 600 }}"
            alt="{{ perfume_name | escape }}"
            loading="lazy"
            width="600"
            height="300"
          >
        {% endif %}

        <div class="info">
          <h3>{{ perfume_name }}</h3>
          {% if display_note != blank %}
            <p>{{ display_note }}</p>
          {% endif %}
        </div>

      </a>
    {% endfor %}

  </div>

</section>

<style>
/* ======================================================= */
/* 💻 أولاً: تنسيق نسخة اللاب توب والكمبيوتر (Desktop) */
/* ======================================================= */
.signature {
  padding: 120px 0;
  text-align: center;
  background-color: #0B0B0B;
}

.signature h2 {
  font-family: "Playfair Display", serif;
  color: #C8A060;
  margin-bottom: 50px;
  font-size: 42px;
  letter-spacing: 1px;
  opacity: 0;
  transform: translateY(-15px);
  transition: opacity 1s cubic-bezier(0.25, 1, 0.5, 1), transform 1s cubic-bezier(0.25, 1, 0.5, 1);
}

.signature.sig-activated h2 {
  opacity: 1;
  transform: translateY(0);
}

.signature .grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 25px;
}

.signature .card {
  background: #111111;
  border: 1px solid #242424;
  text-decoration: none;
  color: #F7F4EE;
  display: flex;
  flex-direction: column;
  height: 100%;
  opacity: 0;
  transform: translateY(40px);
  /* جعل الترانزيشن فخم وناعم جداً في الـ Hover والـ الـ Scroll */
  transition: opacity 0.8s cubic-bezier(0.25, 1, 0.5, 1), 
              transform 0.5s cubic-bezier(0.25, 1, 0.5, 1), 
              border-color 0.4s ease, 
              box-shadow 0.4s ease;
}

.signature.sig-activated .sig-anim-card {
  opacity: 1;
  transform: translateY(0);
  transition-delay: calc(var(--card-index, 0) * 0.12s);
}

/* 🛠️ تعديل تأثير الـ Hover للنسخة المكتبية: رفعة خفيفة 6px مع زوم خفيف وبدون بوظان للـ Layout */
.signature.sig-activated .card.scale-hover:hover {
  transform: translateY(-6px) scale(1.02);
  border-color: #C8A060;
  box-shadow: 0 12px 30px rgba(0, 0, 0, 0.4);
}

.signature .card img {
  width: 100%;
  height: 300px;
  object-fit: cover;
}

.info {
  padding: 20px;
  text-align: center;
}

.info h3 {
  font-family: "Playfair Display", serif;
  color: #C8A060;
  font-size: 22px;
  margin: 0 0 8px 0;
}

.info p {
  font-family: "Montserrat", sans-serif;
  color: #A3ADB5;
  font-size: 14px;
  margin: 0;
  line-height: 1.4;
}

/* ======================================================= */
/* 📱 تنسيق الموبايل بنمط الـ Staggered Grid */
/* ======================================================= */
@media (max-width: 768px) {
  .signature {
    padding: 60px 16px !important;
  }

  .signature h2 {
    font-size: 28px !important;
    margin-bottom: 40px !important;
  }

  .signature .grid {
    display: grid !important;
    grid-template-columns: repeat(2, 1fr) !important;
    gap: 16px !important; 
    align-items: start !important; 
  }

  .signature .card {
    border-radius: 4px !important; 
    background: #111111 !important;
    display: flex !important;
    flex-direction: column !important;
    height: auto !important; 
  }

  .signature .card img {
    height: 180px !important; 
    object-fit: cover !important;
  }

  .info {
    padding: 12px 8px !important;
  }

  .info h3 {
    font-size: 16px !important;
    margin-bottom: 4px !important;
  }

  .info p {
    font-size: 11px !important;
    line-height: 1.3 !important;
  }
  
  .signature .card:nth-child(even) {
    --zig-y: 150px;
    margin-bottom: 45px !important; 
  }

  .signature .card:nth-child(odd) {
    --zig-y: 0px;
    margin-bottom: 45px !important;
  }

  .signature .sig-anim-card {
    transform: translateY(calc(40px + var(--zig-y, 0px)));
  }

  .signature.sig-activated .sig-anim-card {
    opacity: 1 !important;
    transform: translateY(var(--zig-y, 0px)) !important;
    transition-delay: calc(var(--card-index, 0) * 0.1s);
  }

  /* 🛠️ حل المشكلة السحري للموبايل: نأخذ قيمة الـ المتغير --zig-y ونطرح منها 6px فقط للرفعة الفخمة أثناء الـ Hover مع دمج الـ Scale */
  .signature.sig-activated .card.scale-hover:hover {
    transform: translateY(calc(var(--zig-y, 0px) - 6px)) scale(1.02) !important;
    border-color: #C8A060;
  }
}

.no-js .signature h2, 
.no-js .signature .card {
  opacity: 1 !important;
  transform: none !important;
}
@media (max-width: 768px) {
  .no-js .signature .card:nth-child(even) {
    transform: translateY(150px) !important;
  }
}
</style>

<script>
(function() {
  function initSigAnimation() {
    const section = document.getElementById('sig-section-{{ section.id }}');
    if (!section) return;

    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            section.classList.add('sig-activated');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15, rootMargin: '0px 0px -50px 0px' });
      
      observer.observe(section);
    } else {
      section.classList.add('sig-activated');
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSigAnimation);
  } else {
    initSigAnimation();
  }
  document.addEventListener('shopify:section:load', initSigAnimation);
})();
</script>

{% schema %}
{
  "name": "Signature Collection",
  "settings": [
    { 
      "type": "text", 
      "id": "title", 
      "label": "Title", 
      "default": "Signature Collection" 
    }
  ],
  "blocks": [
    {
      "type": "perfume",
      "name": "Perfume",
      "settings": [
        { 
          "type": "product", 
          "id": "product", 
          "label": "Select Product" 
        },
        { 
          "type": "text", 
          "id": "name", 
          "label": "Custom Name (Optional)"
        },
        { 
          "type": "text", 
          "id": "note", 
          "label": "Custom Note (Fallback)"
        },
        { 
          "type": "image_picker", 
          "id": "image", 
          "label": "Custom Image (Optional)"
        },
        { 
          "type": "url", 
          "id": "link", 
          "label": "Custom Link (Optional)"
        }
      ]
    }
  ],
  "presets": [{ "name": "Signature Collection" }]
}
{% endschema %}